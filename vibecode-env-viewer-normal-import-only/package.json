{
  "name": "vibecode-env-viewer-normal-import-only",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.2.0",
  "publisher": "dalsoop",
  "engines": {
    "vscode": "^1.95.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run sync && tsc -p .",
    "watch": "tsc -p . -w",
    "sync": "node scripts/sync-nls.mjs",
    "sync:check": "node scripts/sync-nls.mjs --check",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vscode:prepublish": "npm run build",
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "vibecodeEnvViewerNormalImport.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": ".env"
          },
          {
            "filenamePattern": ".env.local"
          },
          {
            "filenamePattern": ".env.development"
          },
          {
            "filenamePattern": ".env.production"
          },
          {
            "filenamePattern": ".env.staging"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "license": "MIT"
}
