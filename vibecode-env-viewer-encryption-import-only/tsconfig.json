{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDirs": ["src", "../packages/vibecode-core"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.ts",
    "src/contracts/**/*.d.ts",
    "../packages/vibecode-core/crypto/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/webview/client"]
}
