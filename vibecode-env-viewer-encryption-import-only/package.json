{
  "name": "vibecode-env-viewer-encryption-import-only",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "dalsoop",
  "engines": {
    "vscode": "^1.95.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run sync && tsc -p .",
    "watch": "tsc -p . -w",
    "sync": "node scripts/sync-nls.mjs",
    "sync:check": "node scripts/sync-nls.mjs --check",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vscode:prepublish": "npm run build",
    "package": "npx --yes @vscode/vsce@latest package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  },
  "contributes": {
    "commands": [
      {
        "command": "vibecode-env-viewer-encryption.enableEncryption",
        "title": "%command.enableEncryption.title%",
        "category": "%command.category%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vibecode-env-viewer-encryption.enableEncryption",
          "when": "resourceFilename =~ /^\\.env(\\..+)?$/ && !(resourceFilename == .env.keys)",
          "group": "7_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "vibecode-env-viewer-encryption.enableEncryption"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "vibecodeEnvViewerEncryptionImport.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          { "filenamePattern": ".env" },
          { "filenamePattern": ".env.local" },
          { "filenamePattern": ".env.development" },
          { "filenamePattern": ".env.production" },
          { "filenamePattern": ".env.staging" }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "vibecodeEnvViewerEncryption.strategy": {
          "type": "string",
          "enum": ["none", "dotenvx", "infisical"],
          "default": "none",
          "enumDescriptions": [
            "%config.strategy.none.description%",
            "%config.strategy.dotenvx.description%",
            "%config.strategy.infisical.description%"
          ],
          "description": "%config.strategy.description%"
        }
      }
    }
  },
  "dependencies": {
    "eciesjs": "^0.5.0"
  }
}
