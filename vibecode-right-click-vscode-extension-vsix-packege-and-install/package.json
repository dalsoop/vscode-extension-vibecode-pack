{
  "name": "vibecode-right-click-vscode-extension-vsix-packege-and-install",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "dalsoop",
  "engines": {
    "vscode": "^1.95.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run sync && tsc -p .",
    "watch": "tsc -p . -w",
    "sync": "node scripts/sync-contributions.mjs",
    "sync:check": "node scripts/sync-contributions.mjs --check",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vscode:prepublish": "npm run build",
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  },
  "contributes": {
    "commands": [
      {
        "command": "rcaVsixPackageInstall.packageAndInstall",
        "title": "%cmd.packageAndInstall%",
        "category": "%ext.category%",
        "icon": "$(package)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rcaVsixPackageInstall.packageAndInstall",
          "when": "explorerResourceIsFolder",
          "group": "6_rca@20"
        }
      ],
      "commandPalette": [
        {
          "command": "rcaVsixPackageInstall.packageAndInstall"
        }
      ]
    }
  }
}
