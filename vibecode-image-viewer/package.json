{
  "name": "vibecode-image-viewer",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.0",
  "publisher": "dalsoop",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "npm run sync && node scripts/build-ext.mjs --production",
    "watch": "node scripts/build-ext.mjs --watch",
    "sync": "node scripts/sync-nls.mjs",
    "sync:check": "node scripts/sync-nls.mjs --check",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vscode:prepublish": "npm run build",
    "package": "npx --yes @vscode/vsce@latest package --no-dependencies --allow-missing-repository --skip-license",
    "build:dev": "npm run sync && node scripts/build-ext.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "image-size": "^1.1.1"
  },
  "contributes": {
    "configuration": {
      "title": "%ext.category%",
      "properties": {
        "vibecodeImageViewer.defaultTab": {
          "type": "string",
          "default": "overview",
          "enum": ["overview", "exif", "png-text", "raw"],
          "enumDescriptions": [
            "%config.defaultTab.overview%",
            "%config.defaultTab.exif%",
            "%config.defaultTab.pngText%",
            "%config.defaultTab.raw%"
          ],
          "description": "%config.defaultTab%"
        },
        "vibecodeImageViewer.rawJsonExpanded": {
          "type": "boolean",
          "default": true,
          "description": "%config.rawJsonExpanded%"
        },
        "vibecodeImageViewer.pngTextShowAiPromptFormatted": {
          "type": "boolean",
          "default": true,
          "description": "%config.pngTextShowAiPromptFormatted%"
        }
      }
    },
    "commands": [
      {
        "command": "vibecodeImageViewer.openSettings",
        "title": "%cmd.openSettings%",
        "category": "%ext.category%",
        "icon": "$(gear)"
      }
    ],
    "customEditors": [
      {
        "viewType": "vibecodeImageViewer.editor",
        "displayName": "%editor.displayName%",
        "selector": [
          { "filenamePattern": "*.png" },
          { "filenamePattern": "*.jpg" },
          { "filenamePattern": "*.jpeg" },
          { "filenamePattern": "*.webp" },
          { "filenamePattern": "*.gif" },
          { "filenamePattern": "*.bmp" },
          { "filenamePattern": "*.avif" },
          { "filenamePattern": "*.heic" },
          { "filenamePattern": "*.heif" },
          { "filenamePattern": "*.svg" },
          { "filenamePattern": "*.ico" },
          { "filenamePattern": "*.PNG" },
          { "filenamePattern": "*.JPG" },
          { "filenamePattern": "*.JPEG" }
        ],
        "priority": "default"
      }
    ]
  },
  "license": "MIT"
}
